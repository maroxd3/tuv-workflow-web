[mariadb]

character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

# Binary Logging — Voraussetzung für Point-in-Time-Recovery (Backup-Tier 1)
# Jede Schreib-Operation wird ins Binlog protokolliert. Wir können damit jede
# Sekunde der letzten 14 Tage rekonstruieren (siehe docs/backup.md).
log_bin           = /var/lib/mysql/mysql-bin
binlog_format     = ROW
expire_logs_days  = 14
sync_binlog       = 1
server_id         = 1

# Erlaubt dem Anwendungs-Nutzer (tuv_app), Trigger/Stored Routines anzulegen,
# ohne SUPER-Privileg. Bei aktivem Binlog blockiert MariaDB das sonst, weil es
# fuer Replikations-Setups potenziell unsicher waere. Wir replizieren nicht
# (On-Premise pro Kunde, single-instance), und der WF-01-Trigger schreibt nur
# eine SIGNAL — keine Daten-Aenderung mit replikations-relevanten Seiten-
# effekten. Damit ist der Schalter hier korrekt.
log_bin_trust_function_creators = 1

# Sinnvolle Defaults für eine kleine Prüfstelle (5–20 gleichzeitige Nutzer).
max_connections           = 100
innodb_buffer_pool_size   = 256M
innodb_flush_log_at_trx_commit = 1
