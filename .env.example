# Firebase Web Client Config — Vite injects these into the production bundle.
# Copy this file to `.env` and fill in the real values from your Firebase
# project settings (https://console.firebase.google.com/).
#
# These keys are NOT secrets — Firebase Web API keys are public by design and
# end up in every browser that loads the app. Real access control is enforced
# server-side via Firestore Security Rules (see firestore.rules). The .env file
# is gitignored anyway, mainly to keep GitHub's secret scanner happy.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
