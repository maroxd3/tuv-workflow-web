# Datenbank-Zugang
# Lokal ohne Docker: MARIADB_HOST=127.0.0.1, USER=root oder eigener Setup
# Mit docker-compose: MARIADB_HOST=db, USER aus den Compose-Defaults
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=tuv_app
MARIADB_PASSWORD=tuv_app_pw
MARIADB_DATABASE=tuv_workflow

# Nur für docker-compose: root-Passwort für das MariaDB-Container-Setup.
# In Produktion unbedingt ändern und sicher aufbewahren (Backup-Restore-Key!)
MARIADB_ROOT_PASSWORD=please_change_me_in_production

# Express-API
API_PORT=8787

# NODE_ENV: "production" aktiviert den Fail-fast-Check unten. Bei einem
# Customer-Setup IMMER auf "production" setzen.
NODE_ENV=development

# Admin-Token: schützt /api/admin/reset und /api/admin/demo (DB-Wipe + Reseed).
# Leerer Wert + NODE_ENV=development = Dev-Modus (Endpunkte öffentlich, Warnung im Log).
# Leerer Wert + NODE_ENV=production  = Server verweigert den Start.
#
# In Produktion ZWINGEND setzen. Ohne Token kann jeder im LAN die Datenbank
# löschen. Mindestens 32 Zeichen, z. B.:
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#   bash/zsh:   openssl rand -hex 32
ADMIN_TOKEN=

# CORS: zusätzliche erlaubte Origins (Komma-getrennt). localhost/127.0.0.1
# und RFC-1918 Private-LAN-Bereiche (10.x, 192.168.x, 172.16-31.x) sind
# immer erlaubt. Beispiel: ALLOWED_ORIGINS=https://werkstatt.example.de
ALLOWED_ORIGINS=

# Frontend → API
VITE_API_BASE_URL=/api
